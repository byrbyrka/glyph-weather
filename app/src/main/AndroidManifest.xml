<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Access to the Glyph Matrix -->
    <uses-permission android:name="com.nothing.ketchum.permission.ENABLE" />

    <!--
      WorkManager's own manifest declares RECEIVE_BOOT_COMPLETED (for its disabled
      RescheduleReceiver) and WAKE_LOCK. Neither is used by this app — we don't have
      a boot receiver — but the manifest merger pulls them in from the dependency by
      default. That combination (boot persistence + wake lock + location + foreground
      service) matches heuristic spyware signatures in some AV engines, so explicitly
      strip them back out.
    -->
    <uses-permission
        android:name="android.permission.RECEIVE_BOOT_COMPLETED"
        tools:node="remove" />
    <uses-permission
        android:name="android.permission.WAKE_LOCK"
        tools:node="remove" />

    <!-- Weather/network -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!-- Location for determining current weather -->
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />

    <!-- Foreground service that renders the animation on the matrix -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_LOCATION" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <application
        android:name=".GlyphWeatherApp"
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher"
        android:supportsRtl="true"
        android:theme="@style/Theme.GlyphWeather">

        <!-- Metadata for Glyph SDK v2.0 -->
        <meta-data
            android:name="NothingKey"
            android:value="glyph_weather_key" />
        <meta-data
            android:name="TargetDevice"
            android:value="A069P" />
        <meta-data
            android:name="targetNothingSDKVersion"
            android:value="140101" />

        <activity
            android:name=".ui.MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <service
            android:name=".glyph.GlyphWeatherService"
            android:exported="false"
            android:foregroundServiceType="location" />

        <!--
          This app has no boot receiver of its own. Explicitly disable WorkManager's
          BOOT_COMPLETED-listening RescheduleReceiver so it doesn't reintroduce boot
          persistence behavior even if the permission removal above is bypassed.
        -->
        <receiver
            android:name="androidx.work.impl.background.systemalarm.RescheduleReceiver"
            android:enabled="false"
            tools:node="merge" />

    </application>
</manifest>
