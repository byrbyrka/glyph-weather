<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Access to the Glyph Matrix -->
    <uses-permission android:name="com.nothing.ketchum.permission.ENABLE" />

    <!-- Weather/network -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!-- Location for determining current weather -->
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />

    <!-- Foreground service that renders the animation on the matrix -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_LOCATION" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <application
        android:name=".GlyphWeatherApp"
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher"
        android:supportsRtl="true"
        android:theme="@style/Theme.GlyphWeather">

        <!-- Metadata for Glyph SDK v2.0 -->
        <meta-data
            android:name="NothingKey"
            android:value="glyph_weather_key" />
        <meta-data
            android:name="TargetDevice"
            android:value="A069P" />
        <meta-data
            android:name="targetNothingSDKVersion"
            android:value="140101" />

        <activity
            android:name=".ui.MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <service
            android:name=".glyph.GlyphWeatherService"
            android:exported="false"
            android:foregroundServiceType="location" />

    </application>
</manifest>
